generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Food {
  id        String         @id @default(uuid())
  name      String
  createdAt DateTime       @default(now())
  nutrition FoodNutrition?
}

model FoodNutrition {
  foodId   String @id
  calories Float?
  protein  Float?
  fat      Float?
  carbs    Float?
  food     Food   @relation(fields: [foodId], references: [id], onDelete: Cascade)
}
